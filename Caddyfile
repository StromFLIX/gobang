{
	auto_https off
	admin off
}

:80 {
	encode zstd gzip

	@pocketbase_oauth_success path /pb/_/
	handle @pocketbase_oauth_success {
		header Content-Type "text/html; charset=utf-8"
		respond "<!doctype html><html lang=\"en\"><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"><title>Google sign-in complete</title><script>const fallback='https://gobang.stromflix.com/account?mode=login';if(window.opener){window.close()}else if(/Android/i.test(navigator.userAgent)){window.location.replace('intent://gobang.stromflix.com/oauth-complete#Intent;scheme=https;package=com.stromflix.gobang;S.browser_fallback_url='+encodeURIComponent(fallback)+';end')}else{window.location.replace(fallback)}</script></head><body><main><h1>Sign-in complete</h1><p><a href=\"/account?mode=login\">Return to Gobang</a></p></main></body></html>" 200
	}

	@pocketbase_admin path /pb/_* /pb/api/backups* /pb/api/collections /pb/api/settings*
	handle @pocketbase_admin {
		respond 404
	}

	handle_path /pb/* {
		reverse_proxy {
			dynamic a {$POCKETBASE_UPSTREAM:pocketbase} 8090 {
				refresh 1s
				resolvers 127.0.0.11
				versions ipv4
			}
			lb_try_duration 5s
			flush_interval -1
		}
	}

	handle {
		reverse_proxy {
			dynamic a {$APP_UPSTREAM:app} 8000 {
				refresh 1s
				resolvers 127.0.0.11
				versions ipv4
			}
			lb_try_duration 5s
		}
	}
}
