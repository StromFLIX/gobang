APP_PORT=8080
PB_SUPERUSER_EMAIL=gobang-service@example.com
PB_SUPERUSER_PASSWORD=replace-with-a-long-random-password

# PocketBase transactional email. Keep disabled until the sender domain and SMTP credentials exist.
PB_APP_NAME=Gobang
PB_APP_URL=http://localhost:8080
PB_MAIL_SENDER_NAME=Go Bang
PB_MAIL_SENDER_ADDRESS=
PB_SMTP_ENABLED=false
PB_SMTP_HOST=
PB_SMTP_PORT=587
PB_SMTP_USERNAME=
PB_SMTP_PASSWORD=
PB_SMTP_AUTH_METHOD=PLAIN
# false negotiates StartTLS; true requires TLS from the initial connection (commonly port 465).
PB_SMTP_TLS=false
PB_SMTP_LOCAL_NAME=

# Google Web OAuth client used by PocketBase. The callback URL is
# https://your-public-origin/pb/api/oauth2-redirect.
PB_GOOGLE_AUTH_ENABLED=false
PB_GOOGLE_CLIENT_ID=
PB_GOOGLE_CLIENT_SECRET=

FIREBASE_CREDENTIALS_JSON=
ANDROID_APP_LINK_SHA256_CERT_FINGERPRINTS=04:3F:9D:9A:92:E2:40:7A:F0:A3:46:B0:5B:3D:4C:72:47:C7:D7:95:BE:55:2C:75:1B:A7:13:3F:CD:7B:25:BC

# Public legal-notice details embedded into the frontend at image build time.
LEGAL_OPERATOR_NAME=
# Postal details are passed only to the backend at runtime and revealed on request.
LEGAL_STREET_ADDRESS=
LEGAL_POSTAL_CITY=
LEGAL_COUNTRY=
LEGAL_EMAIL=
# Add these only when legally applicable.
LEGAL_REGISTER_ENTRY=
LEGAL_VAT_ID=
LEGAL_HOSTING_PROVIDER=
LEGAL_HOSTING_LOCATION=
